# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (local default; docker-compose overrides POSTGRES_HOST to 'db')
POSTGRES_DB=edupage_killer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (local default; docker-compose overrides REDIS_URL to use the 'redis' service)
REDIS_URL=redis://localhost:6379/0

# Social Auth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social Auth - Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Social Auth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# EduPage credentials (for sync)
EDUPAGE_SERVER=
EDUPAGE_USERNAME=
EDUPAGE_PASSWORD=

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173

# File storage (local for dev, S3 for prod)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
